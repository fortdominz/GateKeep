# GateKeep — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore and will never be committed.

# ── Backend ───────────────────────────────────────────────────────────────────

# Admin panel password (set a strong one in production)
# Locally defaults to "admin" if not set.
# On Render: set this in the dashboard as a secret environment variable.
ADMIN_PASSWORD=your_strong_password_here

# Where to store the SQLite DB and snapshots.
# Locally defaults to the repo root. On Render, set to /data (persistent disk).
# GATEKEEP_DATA_DIR=/data

# Where InsightFace stores the buffalo_l model (~600MB).
# On Render, set to /data/.insightface so it persists across deploys.
# INSIGHTFACE_HOME=/data/.insightface

# ── Frontend (Vite) ───────────────────────────────────────────────────────────

# Backend URL for production builds.
# Locally this is empty (Vite proxy handles /api → localhost:8090).
# On Vercel: set to https://gatekeep-api.onrender.com
# VITE_API_URL=https://gatekeep-api.onrender.com
